{
  "name": "@longrun-ai/shell",
  "version": "1.17.5",
  "description": "Dominds shell-facing contract package.",
  "type": "commonjs",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node ../../scripts/rm-dir.mjs dist",
    "format": "prettier --write \"src/**/*.{ts,md,json}\" README.md package.json tsconfig.json",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "node ../../scripts/require-pnpm-publish.mjs && pnpm run build"
  },
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11.16.0",
    "pnpm": ">=11.5.0"
  },
  "dependencies": {
    "@longrun-ai/kernel": "workspace:*"
  },
  "license": "LGPL-3.0-or-later"
}
