{
  "name": "@longrun-ai/kernel",
  "version": "1.8.11",
  "description": "Dominds kernel public contracts for app handshake/runtime integration.",
  "type": "commonjs",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.3",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./app-json": {
      "types": "./src/app-json.ts",
      "require": "./dist/app-json.js",
      "default": "./dist/app-json.js"
    },
    "./app-host-contract": {
      "types": "./src/app-host-contract.ts",
      "require": "./dist/app-host-contract.js",
      "default": "./dist/app-host-contract.js"
    },
    "./evt": {
      "types": "./src/evt.ts",
      "require": "./dist/evt.js",
      "default": "./dist/evt.js"
    },
    "./diligence": {
      "types": "./src/diligence.ts",
      "require": "./dist/diligence.js",
      "default": "./dist/diligence.js"
    },
    "./team-mgmt-guide": {
      "types": "./src/team-mgmt-guide.ts",
      "require": "./dist/team-mgmt-guide.js",
      "default": "./dist/team-mgmt-guide.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "require": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "require": "./dist/types/*.js",
      "default": "./dist/types/*.js"
    },
    "./utils/time": {
      "types": "./src/utils/time.ts",
      "require": "./dist/utils/time.js",
      "default": "./dist/utils/time.js"
    },
    "./utils/html": {
      "types": "./src/utils/html.ts",
      "require": "./dist/utils/html.js",
      "default": "./dist/utils/html.js"
    },
    "./utils/id": {
      "types": "./src/utils/id.ts",
      "require": "./dist/utils/id.js",
      "default": "./dist/utils/id.js"
    }
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "format": "prettier --write \"src/**/*.{ts,md,json}\" README.md package.json tsconfig.json",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "node ../../scripts/require-pnpm-publish.mjs && pnpm run build"
  },
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11.9.0",
    "pnpm": ">=10.30.3"
  },
  "license": "LGPL-3.0-or-later"
}
