{
  "name": "dominds-webapp",
  "version": "0.0.0",
  "private": true,
  "license": "LGPL-3.0-or-later",
  "description": "dominds webui/frontend",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11.9.0",
    "pnpm": ">=10.30.3"
  },
  "scripts": {
    "start": "echo 'Dominds WebApp is served by backend server.' && echo 'Dev: cd ../../ && ./dev-server.sh'",
    "dev": "echo 'Dominds WebApp is served by backend server.' && echo 'Dev: cd ../../ && ./dev-server.sh'",
    "test": "echo 'Dominds WebApp: Use lint:types for type checking.'",
    "build": "vite build",
    "clean": "rm -rf dist",
    "serve": "echo 'Dominds WebApp is served by backend server.' && echo 'Dev: cd ../../ && ./dev-server.sh'",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\" && prettier --write \"src/**/*.{css,md,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\" && prettier --check \"src/**/*.{css,md,json,html}\"",
    "lint:types": "tsc -p src/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@longrun-ai/kernel": "workspace:*",
    "@longrun-ai/shell": "workspace:*",
    "dompurify": "^3.3.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.37",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3",
    "ts-dedent": "^2.2.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "vite": "^7.3.1"
  }
}
