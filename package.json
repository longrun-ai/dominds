{
  "name": "dominds",
  "version": "1.9.4",
  "description": "Dominds CLI and aggregation shell for the LongRun AI kernel/runtime packages.",
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dominds": "dist/cli.js"
  },
  "exports": {
    "./cli": {
      "types": "./dist/cli.d.ts",
      "require": "./dist/cli.js",
      "default": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "webapp/dist/**/*",
    "LICENSE",
    "README.md",
    "README.zh.md",
    "package.json"
  ],
  "scripts": {
    "start": "echo 'Dominds backend runs via outer rtws dev-server.' && echo 'Dev: cd .. && ./dev-server.sh'",
    "dev": "echo 'Dominds backend runs via outer rtws dev-server.' && echo 'Dev: cd .. && ./dev-server.sh'",
    "test": "echo 'Dominds backend: Use lint:types for type checking.'",
    "serve": "echo 'Dominds backend runs via outer rtws dev-server.' && echo 'Dev: cd .. && ./dev-server.sh'",
    "setup:pm": "corepack enable pnpm && corepack install",
    "manual": "pnpm exec tsx main/cli/manual.ts",
    "release:publish-public": "node ./scripts/publish-public-packages.mjs",
    "release:publish-public:dry-run": "node ./scripts/publish-public-packages.mjs --dry-run",
    "prepare": "pnpm run build:workspace",
    "prepublishOnly": "node ./scripts/require-pnpm-publish.mjs && pnpm run build",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:workspace": "pnpm -r --filter './packages/*' --filter ./codex-auth --filter ./webapp run build",
    "build:frontend": "pnpm -C webapp run build",
    "clean": "rm -rf ./dist && pnpm -r --filter './packages/*' --filter ./codex-auth --filter ./webapp run clean",
    "lint": "pnpm run lint:types && pnpm run format:check",
    "lint:types": "pnpm -r --filter './packages/*' --filter ./webapp run lint:types && tsc -p main/tsconfig.dev.json --noEmit",
    "format": "prettier --write \"{main,webapp/src,docs,tests}/**/*.{js,jsx,ts,tsx}\" && prettier --write \"{main,webapp/src,docs,tests}/**/*.{css,md,json,html}\"",
    "format:check": "prettier --check \"{main,webapp/src,docs,tests}/**/*.{js,jsx,ts,tsx}\" && prettier --check \"{main,webapp/src,docs,tests}/**/*.{css,md,json,html}\"",
    "build:backend": "pnpm -r --filter './packages/*' --filter ./codex-auth run build && tsc -p main/tsconfig.json && mkdir -p dist/llm dist/minds dist/tools dist/snippets dist/docs && cp main/llm/defaults.yaml dist/llm/ && cp -r main/minds/builtin dist/minds/ && cp -r main/tools/prompts dist/tools/ && cp -r snippets/. dist/snippets/ && cp -r docs/. dist/docs/ && chmod +x ./dist/cli.js ./dist/cli/*.js 2>/dev/null"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/longrun-ai/dominds.git"
  },
  "keywords": [
    "agentic",
    "devops"
  ],
  "author": "Compl Yue",
  "license": "LGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/longrun-ai/dominds/issues"
  },
  "homepage": "https://github.com/longrun-ai/dominds#readme",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11.9.0",
    "pnpm": ">=10.30.3"
  },
  "dependencies": {
    "@longrun-ai/kernel": "workspace:*",
    "@longrun-ai/shell": "workspace:*",
    "@longrun-ai/codex-auth": "workspace:*",
    "@anthropic-ai/sdk": "^0.78.0",
    "openai": "^6.27.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "async-mutex": "^0.5.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
