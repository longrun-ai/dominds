{
  "name": "@longrun-ai/codex-auth",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.8.0",
  "description": "ChatGPT OAuth helpers compatible with Codex auth.json",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/longrun-ai/dominds.git",
    "directory": "codex-auth"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codex-auth": "bin/codex-auth.js"
  },
  "files": [
    "bin",
    "dist",
    "prompts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "doctor": "node dist/bin/auth-doctor.js",
    "format": "prettier --write \"src/**/*\" \"docs/**/*\" README.md"
  },
  "dependencies": {
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
