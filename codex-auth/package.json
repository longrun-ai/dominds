{
  "name": "@longrun-ai/codex-auth",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.13.0",
  "description": "ChatGPT OAuth helpers compatible with Codex auth.json",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/longrun-ai/dominds.git",
    "directory": "codex-auth"
  },
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codex-auth": "bin/codex-auth.js"
  },
  "files": [
    "bin",
    "dist",
    "prompts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11.16.0",
    "pnpm": ">=11.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node ../scripts/rm-dir.mjs dist",
    "doctor": "node dist/bin/auth-doctor.js",
    "format": "prettier --write \"src/**/*\" \"docs/**/*\" README.md",
    "prepublishOnly": "node ../scripts/require-pnpm-publish.mjs && pnpm run build"
  },
  "dependencies": {
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
